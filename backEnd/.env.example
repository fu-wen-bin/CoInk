# --- 阿里云 OSS（编辑器图片上传 upload/editor-image）---
# 四项均必填且前端 NEXT_PUBLIC_EDITOR_IMAGE_UPLOAD_MODE=oss 时，接口才会成功上传
# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# 可选：对象级 ACL，默认 public-read（方案B：Bucket 私有 + 对象公开读）
# OSS_OBJECT_ACL=public-read
# 可选：自定义 endpoint（内网或兼容地址）
# OSS_ENDPOINT=
# 可选：CDN 或自定义域名（不要末尾斜杠），不填则使用 SDK 返回的 Bucket 公网 URL
# OSS_PUBLIC_BASE_URL=https://cdn.example.com
# 可选：浏览器直传时指定可访问 endpoint（例如 oss-cn-hangzhou.aliyuncs.com 或你的 CNAME 域名）
# OSS_BROWSER_ENDPOINT=
# 可选：公开访问 URL 组装时优先使用该 endpoint（不填则按 region 推导）
# OSS_PUBLIC_ENDPOINT=
# 可选：默认 https；若填 false 则按 http 组装公开 URL
# OSS_SECURE=true
# 可选：签名版本（建议 true）
# OSS_AUTHORIZATION_V4=true

# --- 阿里云 STS（编辑器图片前端直传 multipartUpload + 实时进度）---
# 仅配置以下参数后，/upload/editor-image/sts 才可用
# OSS_STS_ROLE_ARN=acs:ram::1234567890123456:role/your-oss-upload-role
# 可选：会话名（会自动拼接用户标识与时间戳）
# OSS_STS_SESSION_NAME_PREFIX=coink-editor-upload
# 可选：外部 ID（若你的 RAM 角色信任策略要求）
# OSS_STS_EXTERNAL_ID=
# 可选：STS endpoint，默认 sts.aliyuncs.com
# OSS_STS_ENDPOINT=sts.aliyuncs.com
# 可选：临时凭证有效期，范围 900-3600 秒，默认 900
# OSS_STS_DURATION_SECONDS=900
# 可选：前端 multipartUpload 分片参数
# OSS_DIRECT_UPLOAD_PART_SIZE=524288
# OSS_DIRECT_UPLOAD_PARALLEL=3

# --- DeepSeek（编辑器 AI，OpenAI 兼容接口）---
# 复制为 .env 并填写；未配置时 Nest 仍启动，仅 /ai/editor/stream 返回 503
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
# 可选，默认 https://api.deepseek.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选，默认 deepseek-chat
# DEEPSEEK_MODEL=deepseek-chat
# 可选：系统提示词（多行请用引号或自行拆行）
# DEEPSEEK_SYSTEM_PROMPT=你是文档编辑器内的写作助手。

# --- 邮箱验证码登录（SMTP）---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_account@example.com
# SMTP_PASS=your_password_or_app_password
# SMTP_FROM=CoInk <no-reply@example.com>
