# --- 阿里云 OSS（编辑器图片上传 upload/editor-image）---
# 四项均必填且前端 NEXT_PUBLIC_EDITOR_IMAGE_UPLOAD_MODE=oss 时，接口才会成功上传
# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# 可选：自定义 endpoint（内网或兼容地址）
# OSS_ENDPOINT=
# 可选：CDN 或自定义域名（不要末尾斜杠），不填则使用 SDK 返回的 Bucket 公网 URL
# OSS_PUBLIC_BASE_URL=https://cdn.example.com

# --- DeepSeek（编辑器 AI，OpenAI 兼容接口）---
# 复制为 .env 并填写；未配置时 Nest 仍启动，仅 /ai/editor/stream 返回 503
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
# 可选，默认 https://api.deepseek.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选，默认 deepseek-chat
# DEEPSEEK_MODEL=deepseek-chat
# 可选：系统提示词（多行请用引号或自行拆行）
# DEEPSEEK_SYSTEM_PROMPT=你是文档编辑器内的写作助手。
