generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model document_contents {
  document_id String   @id @db.VarChar(21)
  /// Tiptap/ProseMirror JSON（片段 `default`，便于检索、导出与 REST）
  content     Json
  /// Yjs `encodeStateAsUpdate` 快照，协同加载时优先于此（与 content 双写）
  y_state     Bytes?   @db.MediumBlob
  updated_at  DateTime @default(now()) @db.DateTime(0)
  updated_by  String?  @db.VarChar(21)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model document_principals {
  document_id    String                             @db.VarChar(21)
  principal_type document_principals_principal_type
  principal_id   String                             @db.VarChar(21)
  permission     document_principals_permission
  granted_by     String?                            @db.VarChar(21)
  granted_at     DateTime                           @default(now()) @db.DateTime(0)
  updated_at     DateTime                           @default(now()) @db.DateTime(0)
  expires_at     DateTime?                          @db.DateTime(0)

  @@id([document_id, principal_type, principal_id])
  @@index([document_id], map: "idx_doc_principal_doc")
  @@index([principal_type, principal_id], map: "idx_doc_principal_type_id")
}

model document_versions {
  document_id String   @db.VarChar(21)
  /// 快照时间（秒精度）；与 document_id 组成复合主键，避免 MySQL 单列 TIMESTAMP 主键在 Prisma create 回读失败，并允许同一秒内多文档各有一条版本
  version_id  DateTime @db.Timestamp(0)
  title       String   @db.VarChar(512)
  /// 版本说明（用户填写的「快照描述」等）
  description String?  @db.Text
  content     Json
  /// 可选：创建版本时的 Yjs 全量状态（encodeStateAsUpdate），还原时优先于仅 JSON
  y_state     Bytes?   @db.MediumBlob
  created_at  DateTime @default(now()) @db.DateTime(0)
  user_id     String   @db.VarChar(21)

  @@id([document_id, version_id])
}

model documents_info {
  document_id     String                          @id @db.VarChar(21)
  title           String                          @db.VarChar(512)
  type            documents_info_type
  owner_id        String                          @db.VarChar(21)
  parent_id       String?                         @db.VarChar(21)
  sort_order      Int                             @default(0)
  is_deleted      Boolean                         @default(false)
  created_at      DateTime                        @default(now()) @db.DateTime(0)
  updated_at      DateTime                        @default(now()) @db.DateTime(0)
  share_token     String                          @db.VarChar(64)
  link_permission documents_info_link_permission? @default(close)

  @@index([owner_id], map: "idx_documents_owner")
  @@index([parent_id], map: "idx_documents_parent")
  @@index([type], map: "idx_documents_type")
}

/// 用户对文档的最近打开时间（「最近访问」列表按当前用户维度）
model document_user_access {
  document_id      String   @db.VarChar(21)
  user_id          String   @db.VarChar(21)
  last_accessed_at DateTime @default(now()) @db.DateTime(0)

  @@id([document_id, user_id])
  @@index([user_id, last_accessed_at], map: "idx_doc_access_user_time")
}

/// 用户对文档的收藏（按用户维度）
model document_user_star {
  document_id String   @db.VarChar(21)
  user_id     String   @db.VarChar(21)
  created_at  DateTime @default(now()) @db.DateTime(0)

  @@id([document_id, user_id])
  @@index([user_id], map: "idx_doc_star_user")
}

model group_members {
  group_id  String   @db.VarChar(21)
  user_id   String   @db.VarChar(21)
  joined_at DateTime @default(now()) @db.DateTime(0)

  @@id([group_id, user_id])
  @@index([user_id], map: "idx_group_members_user")
}

model groups {
  group_id   String   @id @db.VarChar(21)
  name       String   @db.VarChar(255)
  owner_id   String   @db.VarChar(21)
  created_at DateTime @default(now()) @db.DateTime(0)

  @@index([owner_id], map: "idx_groups_owner")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model notifications {
  notifications_id BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  request_id       BigInt    @db.UnsignedBigInt
  user_id          String    @db.VarChar(21)
  type             String    @db.VarChar(64)
  payload          Json?
  read_at          DateTime? @db.DateTime(0)
  created_at       DateTime  @default(now()) @db.DateTime(0)

  @@index([created_at], map: "idx_created")
  @@index([user_id, read_at], map: "idx_user_read")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model permission_requests {
  request_id        BigInt                                @id @default(autoincrement()) @db.UnsignedBigInt
  document_id       String                                @db.VarChar(21)
  applicant_id      String                                @db.VarChar(21)
  target_permission permission_requests_target_permission
  message           String?                               @db.VarChar(512)
  status            permission_requests_status            @default(pending)
  reviewer_id       String?                               @db.VarChar(21)
  expires_at        DateTime?                             @db.DateTime(0)
  created_at        DateTime                              @default(now()) @db.DateTime(0)
  updated_at        DateTime                              @default(now()) @db.DateTime(0)

  @@index([applicant_id], map: "idx_applicant")
  @@index([document_id, status], map: "idx_doc_status")
  @@index([reviewer_id, status], map: "idx_reviewer_status")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  user_id         String    @id @db.VarChar(21)
  email           String?   @unique(map: "uk_users_email") @db.VarChar(255)
  name            String    @db.VarChar(20)
  password_hash   String?   @db.VarChar(255)
  github_id       BigInt?   @unique(map: "github_id") @db.UnsignedBigInt
  github_username String?   @db.VarChar(255)
  avatar_url      String?   @db.VarChar(512)
  website_url     String?   @db.VarChar(512)
  location        String?   @db.VarChar(255)
  company         String?   @db.VarChar(255)
  bio             String?   @db.Text
  role            String    @default("USER") @db.VarChar(20)
  last_login_at   DateTime? @db.DateTime(0)
  created_at      DateTime  @default(now()) @db.DateTime(0)
  updated_at      DateTime  @default(now()) @db.DateTime(0)
}

enum document_principals_principal_type {
  user
  group
}

enum documents_info_type {
  FILE
  FOLDER
}

enum document_principals_permission {
  view
  comment
  edit
  manage
  full
}

enum permission_requests_target_permission {
  view
  comment
  edit
  manage
  full
}

enum permission_requests_status {
  pending
  approved
  rejected
  cancelled
  expired
}

enum documents_info_link_permission {
  close
  view
  edit
}

model templates {
  template_id   String   @id @db.VarChar(21)
  title         String   @db.VarChar(512)
  description   String?  @db.VarChar(1024)
  content       Json
  category      String   @db.VarChar(64)
  tags          Json?
  thumbnail_url String?  @db.VarChar(512)
  is_public     Boolean  @default(true)
  is_official   Boolean  @default(false)
  creator_id    String   @db.VarChar(21)
  use_count     Int      @default(0)
  created_at    DateTime @default(now()) @db.DateTime(0)
  updated_at    DateTime @default(now()) @db.DateTime(0)

  @@index([category], map: "idx_templates_category")
  @@index([creator_id], map: "idx_templates_creator")
  @@index([is_public], map: "idx_templates_public")
  @@index([is_official], map: "idx_templates_official")
  @@index([title], map: "idx_templates_title")
}

/// 文档评论表：支持评论、回复、解决状态
model document_comments {
  comment_id   String    @id @db.VarChar(21)
  document_id  String    @db.VarChar(21)
  user_id      String    @db.VarChar(21)
  content      String    @db.Text
  parent_id    String?   @db.VarChar(21)
  position     Json?     // 评论在文档中的位置 { blockId, offset }
  is_resolved  Boolean   @default(false)
  resolved_by  String?   @db.VarChar(21)
  resolved_at  DateTime? @db.DateTime(0)
  created_at   DateTime  @default(now()) @db.DateTime(0)
  updated_at   DateTime  @default(now()) @db.DateTime(0)

  @@index([document_id], map: "idx_comments_document")
  @@index([user_id], map: "idx_comments_user")
  @@index([parent_id], map: "idx_comments_parent")
  @@index([is_resolved], map: "idx_comments_resolved")
  @@index([created_at], map: "idx_comments_created")
}

// 博客表
model blogs {
  blog_id     String   @id @db.VarChar(21)
  title       String   @db.VarChar(512)
  summary     String?  @db.VarChar(1024)
  content     Json
  category    String   @db.VarChar(64)
  tags        Json?
  cover_image String?  @db.VarChar(512)
  user_id     String   @db.VarChar(21)
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @default(now()) @db.DateTime(0)

  @@index([user_id], map: "idx_blogs_user")
  @@index([category], map: "idx_blogs_category")
}

// 文件上传表（用于秒传和分片上传跟踪）
model files {
  file_id     String    @id @db.VarChar(21)
  file_hash   String    @unique @db.VarChar(64)
  file_name   String    @db.VarChar(255)
  file_size   Int
  mime_type   String    @db.VarChar(100)
  file_path   String    @db.VarChar(512)
  user_id     String    @db.VarChar(21)
  chunk_count Int?
  is_complete Boolean   @default(false)
  created_at  DateTime  @default(now()) @db.DateTime(0)
  updated_at  DateTime  @default(now()) @db.DateTime(0)

  @@index([file_hash], map: "idx_files_hash")
  @@index([user_id], map: "idx_files_user")
}
